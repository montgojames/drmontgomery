---
import { Image } from 'astro:assets';
import { DoorOpen, HeartPulse, HandHeart, ScrollText } from '@lucide/astro';
import { decisionsGroup, topicHref } from '../data/navigation';
import decisionsPhoto from '../assets/images/decisions-and-next-steps.png';

const topicIcons: Record<string, typeof DoorOpen> = {
  'discharge-planning': DoorOpen,
  resuscitation: HeartPulse,
  'hospice-end-of-life': HandHeart,
  'advance-directives': ScrollText,
};

const topics = decisionsGroup.topics.map((topic) => ({
  ...topic,
  href: topicHref(decisionsGroup, topic),
  icon: topicIcons[topic.slug],
}));
---

<section class="decisions-section">
  <div class="container decisions-section__grid">
    <div class="decisions-section__photo-block">
      <div class="decisions-section__photo">
        <Image
          src={decisionsPhoto}
          alt="An older couple discussing plans together at a table, with a notepad and pen in front of them."
          width={1904}
          height={2544}
        />
      </div>
      <hr class="decisions-section__photo-rule" />
    </div>

    <div class="decisions-section__content">
      <p class="kicker">Decisions & Next Steps</p>
      <h2>Planning for what comes next</h2>
      <hr class="accent-rule" />

      <ul class="topic-list">
        {
          topics.map((topic) => {
            const IconComp = topic.icon;
            return (
              <li>
                <a href={topic.href} class="tappable-card card-row">
                  <IconComp class="topic-icon" stroke-width={1.75} />
                  <div class="topic-text">
                    <h3>{topic.label}</h3>
                    <p>{topic.description}</p>
                  </div>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</section>

<style>
  /* Top padding only — see DuringYourStaySection.astro for why mobile gets
     MORE than desktop's 4rem here, not just parity. */
  .decisions-section {
    padding-top: 7rem;
  }

  /* Label must be literally larger (font-size) than the headline beside
     it, at every width — not just closer in size. Set both as flat,
     non-responsive values (not the vw-based global h2 clamp) so that
     relationship can't invert at some viewport width. Both scaled ~50%
     up again (1.95rem/1.725rem → 2.925rem/2.5875rem) — same ratio
     between the two, just bigger overall. */
  .kicker {
    font-size: 2.19375rem;
  }

  /* See DuringYourStaySection.astro — deliberately tight, tighter than
     the 5rem section-boundary padding above, so proximity signals "this
     photo belongs with this heading," not "new section." */
  .decisions-section__grid {
    display: grid;
    gap: 1.25rem;
  }

  .decisions-section__photo {
    aspect-ratio: 16 / 10;
    border-radius: 1.25rem;
    overflow: hidden;
    background-color: var(--color-warm-gray);
  }

  .decisions-section__photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Echoes the accent-rule under the heading, tying the photo block to the
     rest of the section's terracotta accents. border:none resets the
     browser's default <hr> border, which would otherwise mask the
     background-color. */
  .decisions-section__photo-rule {
    border: none;
    width: 2.75rem;
    height: 3px;
    background-color: var(--color-terracotta);
    border-radius: 2px;
    margin: 0.85rem 0 0;
  }

  .decisions-section__content h2 {
    font-size: 1.940625rem;
    margin-bottom: 0;
  }

  .accent-rule {
    margin-bottom: 0.85rem;
  }

  .topic-list {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  @media (min-width: 48rem) {
    .decisions-section {
      padding-top: 6rem;
    }

    .decisions-section__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
      /* start, not center — the content column is taller than the photo
         (it necessarily sets the row height), and centering the shorter
         photo within that row splits the leftover space above and below
         it, reading as an oversized gap before the next section. */
      align-items: start;
      gap: 3rem;
    }

    .decisions-section__photo {
      aspect-ratio: 4 / 5;
    }

    /* Wider container (site-wide .container, see global.css) means more
       room here too — scale cards and card text up rather than just
       widening the empty margins. Larger text also serves the
       elderly-audience sizing guidance in CLAUDE.md. (Headline font-size
       itself is NOT bumped here — it must stay below the kicker's
       2.19375rem at every width, see the base rule above.) Card text is
       +20% this round; padding trimmed from 1.5rem 1.75rem so the bigger
       text doesn't grow the card's overall footprint. */
    .topic-list {
      gap: 1rem;
    }

    .card-row {
      gap: 1.3rem;
      padding: 1.1rem 1.5rem;
    }

    .topic-icon {
      width: 2.2rem;
      height: 2.2rem;
    }

    .topic-text {
      gap: 0.45rem;
    }

    .topic-text h3 {
      font-size: 1.692rem;
    }

    .topic-text p {
      font-size: 1.422rem;
      line-height: 1.5;
    }
  }
</style>
